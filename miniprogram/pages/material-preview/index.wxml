<view class="hero">
  <view class="eyebrow">资料预览</view>
  <view class="hero-title">{{pageTitle}}</view>
  <view class="badge">资料仅在线查看</view>
</view>
<view class="section">
  <view class="card">
    <view class="bubble">小提示：先看讲义里的例子，再去做小挑战会更轻松。</view>
    <view class="row preview-meta">
      <view class="sub">学习记录已保存</view>
      <view class="sub">带专属水印</view>
    </view>
    <view class="paper">
      <view class="watermark">Gavin · 6235</view>
      <view class="watermark second">Gavin · 6235</view>
      <view class="watermark third">Gavin · 6235</view>
      <view class="paper-title">{{paperTitle}}</view>
      <view class="paper-line"></view>
      <view class="paper-line short"></view>
      <view class="paper-block">📘</view>
      <view class="paper-line"></view>
      <view class="paper-line tiny"></view>
    </view>
    <view class="badges">
      <view class="badge">{{readText}}</view>
      <view class="badge">距离小徽章还差一步</view>
    </view>
    <view class="button-row">
      <button class="button light" bindtap="toggleFavorite">{{favorited ? '已收藏 ✓' : '收藏讲义 ♡'}}</button>
      <button class="button" bindtap="goAnswer">去做小挑战</button>
    </view>
  </view>
</view>
