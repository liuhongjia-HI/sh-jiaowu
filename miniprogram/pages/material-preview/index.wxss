.preview-meta {
  margin: 22rpx 0 0;
}

.paper {
  position: relative;
  min-height: 520rpx;
  margin-top: 24rpx;
  border-radius: 28rpx;
  background: #fffaf6;
  border: 1rpx solid #f1dfd4;
  padding: 34rpx;
  overflow: hidden;
}

.watermark {
  position: absolute;
  left: 10rpx;
  top: 120rpx;
  transform: rotate(-24deg);
  opacity: .055;
  font-size: 32rpx;
  font-weight: 800;
}

.watermark.second {
  left: 250rpx;
  top: 270rpx;
}

.watermark.third {
  left: 40rpx;
  top: 410rpx;
}

.paper-title {
  font-size: 34rpx;
  font-weight: 850;
  margin-bottom: 30rpx;
}

.paper-line {
  height: 20rpx;
  background: #eee3dc;
  border-radius: 999rpx;
  margin-bottom: 22rpx;
}

.paper-line.short {
  width: 70%;
}

.paper-line.tiny {
  width: 52%;
}

.paper-block {
  height: 180rpx;
  border-radius: 24rpx;
  background: #fff2ea;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin: 36rpx 0;
}
