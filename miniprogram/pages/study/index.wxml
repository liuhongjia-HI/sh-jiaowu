<view class="hero">
  <view class="eyebrow">我的学习</view>
  <view class="hero-title">选一门课继续学 📚</view>
</view>

<view class="section">
  <input class="search-box" value="{{keyword}}" placeholder="搜索学习星球 / 老师 / 章节" bindinput="changeKeyword" />
</view>

<view class="section">
  <view class="filter-row">
    <view wx:for="{{filters}}" wx:key="label" class="tag {{item.className}}" data-filter="{{item.label}}" bindtap="changeFilter">{{item.label}}</view>
  </view>
</view>

<view wx:if="{{loading}}" class="empty">正在加载学习内容...</view>
<view wx:elif="{{courses.length === 0}}" class="section">
  <view class="empty-card">
    <view class="title">还没有开通课程</view>
    <view class="sub">{{emptyMessage}}</view>
  </view>
</view>
<view wx:elif="{{visibleCourses.length === 0}}" class="section">
  <view class="empty-card">
    <view class="title">没有找到匹配内容</view>
    <view class="sub">换个关键词，或切回“全部”看看。</view>
  </view>
</view>
<view wx:else class="section">
  <view wx:for="{{visibleCourses}}" wx:key="id" class="card {{item.cardClass}}" bindtap="goDetail" data-id="{{item.id}}">
    <view class="row">
      <view class="cover">{{item.coverIcon}}</view>
      <view>
        <view class="title">{{item.name}}</view>
        <view class="sub">{{item.chapterCount}} 个章节 · {{item.materialNum}} 份资料 · {{item.homeworkNum}} 个小挑战</view>
      </view>
      <view class="badge">{{item.status}}</view>
    </view>
    <view class="badges">
      <view class="badge">{{item.badgeText}}</view>
      <view class="badge">已解锁 {{item.chapterCount}} 节</view>
    </view>
    <view class="progress"><view class="progress-bar" style="width: {{item.progress}}%;"></view></view>
  </view>
</view>
