<view class="hero">
  <view class="eyebrow">我的徽章墙</view>
  <view class="hero-title">已点亮 {{obtainedCount}} 枚徽章 🏅</view>
</view>
<view wx:if="{{loading}}" class="empty">正在加载徽章...</view>
<view wx:else class="section grid2">
  <view wx:for="{{badges}}" wx:key="id" class="card badge-card {{item.obtained ? '' : 'badge-locked'}}">
    <view class="badge-icon">{{item.obtained ? item.icon : '🔒'}}</view>
    <view class="title small-title">{{item.name}}</view>
    <view class="sub">{{item.desc}}</view>
    <view class="muted">{{item.obtained ? '已获得' : '未点亮'}}</view>
  </view>
</view>
