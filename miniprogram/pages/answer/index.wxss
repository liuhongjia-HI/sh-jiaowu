textarea {
  width: 100%;
  min-height: 180rpx;
  border-radius: 24rpx;
  background: #fffaf6;
  border: 1rpx solid #f1dfd4;
  padding: 20rpx;
  box-sizing: border-box;
  margin-top: 18rpx;
}

.option {
  margin-top: 18rpx;
  padding: 22rpx;
  border: 1rpx solid #f1dfd4;
  border-radius: 22rpx;
  background: #fffaf6;
  color: #5d4d45;
  font-size: 26rpx;
  line-height: 1.45;
}

.option.active {
  border-color: #ff9f7f;
  background: #fff1e9;
  color: #d96f45;
  font-weight: 800;
}
