<view class="hero">
  <view class="eyebrow">小挑战</view>
  <view class="hero-title">今天还有几个小挑战等你完成 🌟</view>
</view>

<view class="section">
  <view class="filter-row">
    <view wx:for="{{filters}}" wx:key="label" class="tag {{item.className}}" data-filter="{{item.label}}" bindtap="changeFilter">{{item.label}}</view>
  </view>
</view>
<view wx:if="{{loading}}" class="empty">正在加载小挑战...</view>
<view wx:elif="{{tasks.length === 0}}" class="section">
  <view class="empty-card">
    <view class="title">今天没有待完成的小挑战</view>
    <view class="sub">{{emptyMessage}}</view>
  </view>
</view>
<view wx:elif="{{visibleTasks.length === 0}}" class="section">
  <view class="empty-card">
    <view class="title">这个分类还没有内容</view>
    <view class="sub">切换到“全部”看看当前任务。</view>
  </view>
</view>
<view wx:else class="section">
  <view wx:for="{{visibleTasks}}" wx:key="id" class="card {{item.cardClass}}" bindtap="goAnswer" data-id="{{item.id}}">
    <view class="row">
      <view class="title">{{item.title}}</view>
      <view class="tag">{{item.studentStatus}}</view>
    </view>
    <view class="sub">{{item.course}} · {{item.packageName}}</view>
    <view class="sub">截止 {{item.deadline}} · {{item.questionNum}} 题</view>
    <view class="badges">
      <view class="badge">🎁 {{item.rewardText}}</view>
      <view class="badge">{{item.estimateText}}</view>
    </view>
  </view>
</view>
