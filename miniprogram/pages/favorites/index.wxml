<view class="hero">
  <view class="eyebrow">我收藏的内容</view>
  <view class="hero-title">收藏夹 💖</view>
</view>
<view wx:if="{{loading}}" class="empty">正在加载收藏...</view>
<view wx:elif="{{favorites.length === 0}}" class="section">
  <view class="empty-card">
    <view class="title">还没有收藏</view>
    <view class="sub">{{emptyMessage}}</view>
  </view>
</view>
<view wx:else class="section">
  <view wx:for="{{favorites}}" wx:key="id" class="card" data-type="{{item.targetType}}" data-target="{{item.targetId}}" bindtap="openFavorite">
    <view class="row">
      <view class="title small-title">{{item.targetType === 'material' ? '📖' : '🎯'}} {{item.title}}</view>
      <view class="tag" catchtap="removeFavorite" data-id="{{item.id}}">取消</view>
    </view>
    <view class="sub">{{item.course}}</view>
    <view class="muted">收藏于 {{item.createdAt}}</view>
  </view>
</view>
